# Cloudflare Pages headers. The API sets its own (Go securityHeaders); these
# cover the static web origin.

/*
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Content-Security-Policy: frame-ancestors 'none'
  # REPORT-ONLY (does not block anything) - collects violations at
  # /api/csp-report so the enforcing allowlist is built from real traffic.
  # Clerk + PostHog load scripts at runtime; report-only reveals their exact
  # hosts before we enforce. style 'unsafe-inline' stays (the app uses inline
  # style={} pervasively - low risk). Flip to enforcing after the bake.
  # PostHog serves via the managed reverse proxy use.whensdays.com (scripts +
  # ingest), and Cloudflare Pages auto-injects its Web Analytics beacon from
  # static.cloudflareinsights.com - both must be allow-listed. frame-ancestors
  # is dropped here (it's ignored in a report-only policy and already enforced
  # by the Content-Security-Policy header above).
  Content-Security-Policy-Report-Only: default-src 'self'; script-src 'self' 'unsafe-inline' https://*.clerk.accounts.dev https://*.clerk.com https://js.clerk.com https://challenges.cloudflare.com https://clerk.whensdays.com https://*.posthog.com https://use.whensdays.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://*.clerk.accounts.dev https://*.clerk.com https://clerk.whensdays.com https://*.posthog.com https://*.i.posthog.com https://use.whensdays.com https://cloudflareinsights.com; worker-src 'self' blob:; frame-src 'self' https://*.clerk.accounts.dev https://*.clerk.com https://challenges.cloudflare.com; base-uri 'self'; form-action 'self'; report-uri /api/csp-report

# Vite content-hashed bundles: safe to cache forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Stable public images/icons: a day at the edge, background revalidate.
/icon.svg
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
/hensdays.svg
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
/apple-touch-icon.png
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
/og-card.png
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
