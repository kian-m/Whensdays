# Copy to .env for local dev. Never commit .env.
# --- api ---
API_PORT=8080
APP_ENV=development

# --- database ---
# Local dev (postgres container started by `make db-up`):
DATABASE_URL=postgres://clsandbox:clsandbox@localhost:5432/clsandbox?sslmode=disable
# Production: paste your Neon connection string (keep ?sslmode=require):
# DATABASE_URL=postgres://USER:PASSWORD@ep-xxx.neon.tech/clsandbox?sslmode=require

# --- auth (Clerk) ---
CLERK_SECRET_KEY=sk_test_xxx
# Vite needs this at build time; it is public (publishable) by design:
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
# Clerk testing helpers also read the publishable key under this name:
CLERK_PUBLISHABLE_KEY=pk_test_xxx

# --- analytics (PostHog) ---
# Project API key (phc_...). PUBLIC by design: it is shipped in the web bundle and
# also used by the API to capture. Write-only ingestion key — not a hard secret,
# but manage it as config. Same value in both vars below.
POSTHOG_API_KEY=phc_xxx
VITE_PUBLIC_POSTHOG_KEY=phc_xxx
# Ingestion host (US cloud shown; EU = https://eu.i.posthog.com; or self-hosted):
POSTHOG_HOST=https://us.i.posthog.com
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Web session replay: default on with all text/inputs masked. Set false to disable.
VITE_PUBLIC_POSTHOG_RECORD=true
# Personal API key (phx_...). SECRET — enables server-side feature-flag local
# evaluation (+ deploy annotations in CI). NEVER expose to the browser. Optional:
# leave empty and flags fall back to slower remote evaluation.
POSTHOG_PERSONAL_API_KEY=
# Numeric project id (PostHog → Settings → Project). Only used for CI deploy
# annotations; safe to leave empty otherwise.
POSTHOG_PROJECT_ID=

# --- calendar import/export ---
# CALENDAR_MODE=stub bypasses real providers (Google/Apple) and serves a fixed
# fake calendar — used by the hermetic E2E/docs stacks. Leave empty in prod.
CALENDAR_MODE=
# Public origin of the app, e.g. https://app.example.com. Used to build the
# Google OAuth redirect URI (<APP_ORIGIN>/api/calendar/google/callback) and the
# post-auth return URL. Empty falls back to same-origin relative redirects.
APP_ORIGIN=
# Google OAuth 2.0 Web client (Google Cloud Console → Credentials). Enable the
# Google Calendar API; add the redirect URI above; while the calendar.readonly
# scope is unverified, add yourself as a test user. SECRET — keep server-side.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# 32-byte key (base64) that encrypts stored OAuth tokens at rest (AES-256-GCM).
# Generate: openssl rand -base64 32. SECRET. If empty, tokens are stored as-is.
CALENDAR_TOKEN_KEY=

# --- guests & email ---
# Signs no-account guest tokens (any long random string; openssl rand -base64 32).
# Unset: dev mode uses a fixed key; prod uses an ephemeral key (tokens die on restart).
GUEST_TOKEN_KEY=
# Transactional email (Resend-compatible API). Both empty = emails disabled (no-op).
EMAIL_API_KEY=
EMAIL_FROM=
# Gates POST /api/cron/reminders (24h-before reminder emails). Point a scheduler
# (e.g. Cloud Scheduler, hourly) at it with header X-Cron-Key. Empty = endpoint off.
CRON_KEY=

# Klipy GIF search (event covers). Key from partner.klipy.com — server-side
# only, proxied via GET /api/gifs/search. Empty = GIF picker hidden.
KLIPY_API_KEY=

# --- web ---
WEB_PORT=5173

# --- e2e (a dedicated Clerk test user) ---
E2E_CLERK_USER_USERNAME=test+clerk@example.com
E2E_CLERK_USER_PASSWORD=replace-me
