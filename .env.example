# Copy to .env for local dev. Never commit .env.
# --- api ---
API_PORT=8080
APP_ENV=development

# --- database ---
# Local dev (postgres container started by `make db-up`):
DATABASE_URL=postgres://clsandbox:clsandbox@localhost:5432/clsandbox?sslmode=disable
# Production: paste your Neon connection string (keep ?sslmode=require):
# DATABASE_URL=postgres://USER:PASSWORD@ep-xxx.neon.tech/clsandbox?sslmode=require

# --- auth (Clerk) ---
CLERK_SECRET_KEY=sk_test_xxx
# Vite needs this at build time; it is public (publishable) by design:
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
# Clerk testing helpers also read the publishable key under this name:
CLERK_PUBLISHABLE_KEY=pk_test_xxx

# --- web ---
WEB_PORT=5173

# --- e2e (a dedicated Clerk test user) ---
E2E_CLERK_USER_USERNAME=test+clerk@example.com
E2E_CLERK_USER_PASSWORD=replace-me
